{
  "name": "@sanity/cli",
  "version": "7.4.0",
  "description": "Sanity CLI tool for managing Sanity projects and organizations",
  "keywords": [
    "cli",
    "cms",
    "content",
    "headless",
    "realtime",
    "sanity",
    "tool"
  ],
  "homepage": "https://github.com/sanity-io/cli",
  "bugs": "https://github.com/sanity-io/cli/issues",
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/cli.git",
    "directory": "packages/@sanity/cli"
  },
  "bin": {
    "sanity": "./bin/run.js"
  },
  "files": [
    "./bin",
    "./codemods",
    "./dist",
    "!./dist/**/__tests__",
    "./oclif.config.js",
    "./oclif.manifest.json",
    "./templates"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/exports/index.js",
  "types": "./dist/exports/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/exports/index.ts",
      "default": "./dist/exports/index.js"
    },
    "./_internal": {
      "source": "./src/exports/_internal.ts",
      "default": "./dist/exports/_internal.js"
    },
    "./runtime": {
      "source": "./src/exports/runtime.ts",
      "default": "./dist/exports/runtime.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@oclif/core": "^4.11.7",
    "@oclif/plugin-help": "^6.2.52",
    "@oclif/plugin-not-found": "^3.2.87",
    "@sanity/client": "^7.23.0",
    "@sanity/codegen": "^7.0.3",
    "@sanity/descriptors": "^1.3.0",
    "@sanity/export": "^6.2.0",
    "@sanity/generate-help-url": "^4.0.0",
    "@sanity/id-utils": "^1.0.0",
    "@sanity/import": "^6.0.3",
    "@sanity/migrate": "^7.0.3",
    "@sanity/runtime-cli": "^17.0.0",
    "@sanity/schema": "^6.1.0",
    "@sanity/telemetry": "^1.1.0",
    "@sanity/template-validator": "^3.1.0",
    "@sanity/types": "^6.1.0",
    "@sanity/worker-channels": "^2.0.0",
    "@vercel/frameworks": "3.29.0",
    "@vitejs/plugin-react": "^6.0.3",
    "chokidar": "^5.0.0",
    "console-table-printer": "^2.15.0",
    "date-fns": "^4.4.0",
    "debug": "^4.4.3",
    "dotenv": "^17.4.2",
    "eventsource": "^4.1.0",
    "execa": "^9.6.0",
    "form-data": "^4.0.5",
    "get-latest-version": "^6.0.1",
    "groq-js": "^1.30.2",
    "gunzip-maybe": "^1.4.2",
    "import-meta-resolve": "^4.2.0",
    "is-installed-globally": "^1.0.0",
    "isomorphic-dompurify": "^2.36.0",
    "json5": "^2.2.3",
    "jsonc-parser": "^3.3.1",
    "lodash-es": "^4.18.1",
    "minimist": "^1.2.8",
    "nanoid": "^5.1.11",
    "oneline": "^2.0.0",
    "open": "^11.0.0",
    "p-map": "^7.0.3",
    "package-directory": "^8.2.0",
    "peek-stream": "^1.1.3",
    "picomatch": "^4.0.4",
    "pluralize-esm": "^9.0.5",
    "pretty-ms": "^9.3.0",
    "promise-props-recursive": "^2.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-is": "^19.2.7",
    "rxjs": "^7.8.2",
    "semver": "^7.8.1",
    "skills": "^1.5.9",
    "smol-toml": "^1.6.1",
    "tar": "^7.5.15",
    "tar-fs": "^3.1.2",
    "tar-stream": "^3.2.0",
    "tinyglobby": "^0.2.17",
    "tsx": "^4.22.4",
    "typeid-js": "^1.2.0",
    "vite": "^8.1.0",
    "which": "^6.0.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3",
    "@sanity/cli-build": "^1.1.1",
    "@sanity/cli-core": "^2.1.1",
    "@sanity/workbench-cli": "^1.1.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@sanity/pkg-utils": "^10.5.8",
    "@sanity/ui": "^3.2.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.41",
    "@types/debug": "^4.1.13",
    "@types/gunzip-maybe": "^1.4.3",
    "@types/jsdom": "^28.0.3",
    "@types/lodash-es": "^4.17.12",
    "@types/minimist": "^1.2.5",
    "@types/node": "^22.20.0",
    "@types/picomatch": "^4.0.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-is": "^19.2.0",
    "@types/semver": "^7.7.1",
    "@types/tar-fs": "^2.0.4",
    "@types/tar-stream": "^3.1.4",
    "@types/which": "^3.0.4",
    "@vitest/coverage-istanbul": "^4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "es-module-lexer": "^2.1.0",
    "eslint": "^10.4.1",
    "jsdom": "^29.1.1",
    "nock": "^14.0.15",
    "oclif": "^4.23.16",
    "publint": "^0.3.21",
    "rimraf": "^6.0.1",
    "sanity": "^6.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "@repo/package.config": "0.0.1",
    "@repo/tsconfig": "3.70.0",
    "@sanity/cli-test": "2.0.1",
    "@sanity/eslint-config-cli": "1.1.2"
  },
  "peerDependencies": {
    "babel-plugin-react-compiler": "*"
  },
  "peerDependenciesMeta": {
    "babel-plugin-react-compiler": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "build": "swc --delete-dir-on-start --strip-leading-paths --out-dir dist/ src --ignore '**/*.test.ts' --ignore '**/__tests__/**'",
    "postbuild": "pnpm run manifest:generate && pnpm run check:topic-aliases",
    "build:types": "pkg-utils build --emitDeclarationOnly",
    "check:topic-aliases": "tsx scripts/check-topic-aliases.ts",
    "check:types": "tsc --noEmit",
    "lint": "eslint .",
    "manifest:generate": "oclif manifest",
    "manifest:remove": "rimraf oclif.manifest.json",
    "publint": "publint",
    "readme": "oclif readme --tsconfig-path tsconfig.lib.json --no-source-links",
    "test": "vitest run",
    "posttest": "pnpm run lint",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prewatch": "pnpm run manifest:remove",
    "watch": "swc --delete-dir-on-start --strip-leading-paths --out-dir dist/ --watch src"
  }
}