{
  "name": "@sanity/sdk",
  "version": "2.15.0",
  "private": false,
  "description": "Sanity SDK",
  "keywords": [
    "cms",
    "content",
    "content operating system",
    "headless",
    "realtime",
    "sanity",
    "sdk"
  ],
  "homepage": "https://github.com/sanity-io/sdk/tree/main/packages/core/README.md",
  "bugs": {
    "url": "https://github.com/sanity-io/sdk/issues"
  },
  "license": "MIT",
  "author": "Sanity <developers@sanity.io>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/sdk.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/_exports/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./_internal": {
      "source": "./src/_exports/_internal.ts",
      "import": "./dist/_exports/_internal.js",
      "default": "./dist/_exports/_internal.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@sanity/bifur-client": "^1.0.0",
    "@sanity/client": "^7.23.0",
    "@sanity/comlink": "^4.0.1",
    "@sanity/diff-match-patch": "^3.2.0",
    "@sanity/diff-patch": "^6.0.0",
    "@sanity/id-utils": "^1.0.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/json-match": "^1.0.5",
    "@sanity/message-protocol": "^0.23.0",
    "@sanity/mutate": "^0.18.1",
    "@sanity/telemetry": "^1.1.0",
    "@sanity/types": "^6.1.0",
    "groq": "3.88.1-typegen-experimental.0",
    "groq-js": "^1.30.2",
    "reselect": "^5.1.1",
    "rxjs": "^7.8.2",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@sanity/browserslist-config": "^1.0.5",
    "@sanity/pkg-utils": "^10.5.8",
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "oxfmt": "^0.55.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.9",
    "@repo/config-eslint": "0.0.0",
    "@repo/config-test": "0.0.1",
    "@repo/package.config": "0.0.1",
    "@repo/package.bundle": "3.82.0",
    "@repo/tsconfig": "0.0.1"
  },
  "browserslist": "extends @sanity/browserslist-config",
  "scripts": {
    "build": "pkg build --strict --clean --check",
    "build:bundle": "vite build --configLoader runner --config package.bundle.ts",
    "clean": "rimraf dist",
    "dev": "pkg watch",
    "docs": "typedoc --json docs/typedoc.json --tsconfig ./tsconfig.dist.json",
    "format": "oxfmt",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "ts:check": "tsc --noEmit"
  }
}